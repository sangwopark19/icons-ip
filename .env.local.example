# Supabase (scaffolding) — copy to .env.local and fill in from
# Supabase dashboard → Project Settings → API.
# Until these are set, local public catalog routes use mock data and
# the auth middleware is a no-op.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Legacy projects can still use the anon key as a fallback until Supabase
# removes legacy keys. Prefer NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only secret used to sign the signup confirmation resend state cookie.
# Generate a long random value and keep it out of client-exposed env vars.
AUTH_SIGNUP_RESEND_SECRET=
